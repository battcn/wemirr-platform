<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.battcn.system.provider.mapper.ProxyPoolMapper">


    <insert id="batchInsertProxies" parameterType="java.util.List">
        insert into t_sys_proxy_pool (host,port,anonymity,`type`,`location`,`validate_time`,`locked`,`source`)
        values
        <foreach collection="list" item="item" index="index" separator=",">
            (#{item.host},#{item.port},#{item.anonymity},#{item.type},#{item.location},#{item.validateTime},#{item.locked},#{item.source})
        </foreach>
    </insert>


</mapper>